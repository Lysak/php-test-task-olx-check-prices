[mysqld]
# General Configuration
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# Performance Tuning
innodb_buffer_pool_size = 1024M
max_connections = 1024

# Logging
slow_query_log = 1
slow_query_log_file = /var/log/mariadb/slow.log
long_query_time = 2

# Security
skip-name-resolve
